# ==============================================================================
# Global Configuration for Registry Provisioner
# ==============================================================================

# 1. Target Environment Definitions
DOMAIN="harbor.petasus.io"
NAMESPACE="harbor"
GATEWAY_CLASS="eg"

# 2. Directory Definitions
CERT_DIR="harbor-cert"
