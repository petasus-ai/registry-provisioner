# ==============================================================================
# Registry Provisioner .gitignore
# ==============================================================================

# 1. Auto-generated Project Directories & Files (Critical Security)
# Prevents committing certificates and manifests generated by the scripts.
/harbor-cert/
/manifests/
*.tmp
.*.tmp

# 2. Environment Configuration (Potential Sensitive Data)
# If config.env contains real IPs, domains, or passwords for local use, keep it ignored.
# For collaboration, it's best to share a dummy 'config.env.example' and ignore the real 'config.env'.
config.env

# 3. OS-generated Temporary Files (macOS, Windows, etc.)
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# 4. IDE and Editor Temporary/Config Files (VSCode, IntelliJ, Vim, etc.)
.vscode/
.idea/
.fleet/
*.swp
*.swo
*~
*.bak
*.tmp
*.temp

# 5. Log Files
*.log

# 6. Compressed Archives (Optional)
*.tar
*.tar.gz
*.zip
*.rar
